# Abenlux configuration. Copy to .env; never commit the real secret.

# --- Tier-2 gateway upstreams ---
ABEN_ANTHROPIC_UPSTREAM=https://api.anthropic.com
ABEN_OPENAI_UPSTREAM=https://api.openai.com
ABEN_GOOGLE_UPSTREAM=https://generativelanguage.googleapis.com

# --- privacy ---
# HMAC key for actor pseudonymization. MUST live in a secret store the analytics
# plane cannot read. Rotate per policy. Never commit the real one.
ABEN_HMAC_KEY=change-me-to-a-long-random-secret

# --- derived-layer store ---
ABEN_DB=abenlux.db

# --- company knowledge graph (objectives + repo/ticket joins) ---
ABEN_KG=examples/knowledge_graph.example.yaml

# --- work-context hints (set per detected tool by the desktop agent) ---
ABEN_TOOL=
ABEN_APP_CATEGORY=cli
ABEN_ACTOR=

# --- k-anonymity / differential privacy for management rollups ---
ABEN_K_ANON=5
ABEN_DP_EPSILON=1.0

# --- OTel content capture (Tier-1 tools set these themselves) ---
# CLAUDE_CODE_ENABLE_TELEMETRY=1
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
# OTEL_SEMCONV_STABILITY_OPT_IN=gen_ai_latest_experimental
